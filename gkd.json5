// Hosted GKD subscription for remote updates through GitHub Raw.
{
  id: 2026042701,
  name: '本地自动打卡规则',
  version: 8,
  author: 'fengxuewu-gif',
  updateUrl: 'https://raw.githubusercontent.com/fengxuewu-gif/GKD-rules/main/gkd.json5',
  checkUpdateUrl: 'https://raw.githubusercontent.com/fengxuewu-gif/GKD-rules/main/gkd.json5',
  supportUri: 'https://github.com/gkd-kit/gkd',
  globalGroups: [],
  apps: [
    {
      id: 'com.unionpay',
      name: '云闪付',
      groups: [
        {
          key: 0,
          name: '首页-玩赚中心入口',
          desc: '优先点击首页中部玩赚中心横幅，同轮仅触发一次，避免重复点击影响使用。',
          activityIds: ['com.unionpay.activity.UPActivityMain'],
          matchRoot: true,
          actionCd: 2000,
          actionMaximum: 1,
          resetMatch: 'app',
          rules: [
            {
              key: 0,
              matches: [
                '@[clickable=true] > [text="玩赚中心"] + [text="去抽奖"]',
                '@[clickable=true] > [text="玩赚中心"]',
                '@[clickable=true] > [text="去抽奖"]',
                '[id="com.unionpay:id/float_view"]',
                '[desc="玩赚中心"]',
                '[text="抽大奖"]',
              ],
              snapshotUrls: [
                'local://unionpay-home-banner-entry',
                'local://unionpay-home-entry',
                'local://unionpay-home-entry-activity',
              ],
            },
          ],
        },
      ],
    },
    {
      id: 'com.jingdong.app.mall',
      name: '京东',
      groups: [
        {
          key: 0,
          name: '首页到秒杀页-领京豆两步链路',
          desc: '按两步流程执行：先点首页领京豆/秒杀入口，再点秒杀页赚更多京豆；每步只触发一次。',
          activityIds: [
            'com.jingdong.app.mall.MainFrameActivity',
            'com.jd.lib.ttt.page.TTTMultiPageActivity',
          ],
          matchTime: 20000,
          actionCd: 2500,
          actionMaximum: 1,
          resetMatch: 'app',
          rules: [
            {
              key: 0,
              name: '点击首页入口',
              matches: [
                '[text="领京豆"]',
                '[text="秒杀"]',
              ],
              snapshotUrls: [
                'local://jd-home-jingdou-entry',
                'local://jd-home-mainframe-activity',
              ],
            },
            {
              key: 1,
              name: '点击赚更多京豆',
              preKeys: [0],
              fastQuery: true,
              matches: [
                '[id="homeSignButton"]',
                '[id="secKill_bean_sign_view"]',
                '[text="赚更多京豆"]',
              ],
              snapshotUrls: ['local://jd-seckill-more-beans'],
            },
          ],
        },
      ],
    },
    {
      id: 'com.sgcc.wsgw.cn',
      name: '网上国网',
      groups: [
        {
          key: 0,
          name: '首页-签到入口',
          desc: '115风格：签到入口同轮仅触发一次，避免同页重复点击。',
          activityIds: ['com.sgcc.wsgw.rnbundle.activity.HomeReactActivity'],
          actionCd: 2000,
          actionMaximum: 1,
          resetMatch: 'app',
          rules: [
            {
              key: 0,
              name: '点击签到',
              fastQuery: true,
              matches: [
                '[desc="签到"]',
                '[text="签到"]',
                '[id="com.sgcc.wsgw.cn:id/sin_tag"]',
              ],
              snapshotUrls: ['local://sgcc-home-signin'],
            },
          ],
        },
      ],
    },
  ],
}

